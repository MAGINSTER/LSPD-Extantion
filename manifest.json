{
  "manifest_version": 3,
  "name": "LSPD Forum Helper",
  "version": "1.0.0",
  "description": "Удобное расширение для форума forum.arizona-rp.com",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://forum.arizona-rp.com/*"],
  "action": {
    "default_title": "LSPD Forum Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://forum.arizona-rp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
